# Database (MySQL for production, SQLite for local testing)
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/ganadi_db
# DATABASE_URL=sqlite:///./petcare.db  # 로컬 테스트용

# JWT
SECRET_KEY=change-this-to-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Server
AI_SERVER_URL=http://localhost:8000

# CORS (프론트엔드 주소)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AWS S3 (선택사항 - 설정하면 S3 사용, 없으면 로컬 저장)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_S3_BUCKET=ganadi-pet-images
# AWS_REGION=ap-northeast-2
